# Exemplos de configuração para diferentes provedores:

# Para MySQL local:
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=suasenha
# MYSQL_DATABASE=mindly

# Para PlanetScale:
# MYSQL_HOST=your-db-host.psdb.cloud
# MYSQL_PORT=3306
# MYSQL_USER=your-username
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=your-database-name

# Para Railway MySQL:
# MYSQL_HOST=containers-us-west-xxx.railway.app
# MYSQL_PORT=xxxx
# MYSQL_USER=root
# MYSQL_PASSWORD=xxxxxxxxxx
# MYSQL_DATABASE=railway

# Para AWS RDS:
# MYSQL_HOST=your-instance.xxxxxxxxx.us-east-1.rds.amazonaws.com
# MYSQL_PORT=3306
# MYSQL_USER=admin
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=mindly

# Configurações do Google OAuth (opcional)
# Para obter essas credenciais:
# 1. Acesse https://console.cloud.google.com/
# 2. Crie um projeto ou selecione um existente
# 3. Vá em "APIs & Services" > "Credentials"
# 4. Clique em "Create Credentials" > "OAuth 2.0 Client IDs"
# 5. Configure como "Web application"
# 6. Adicione suas URLs autorizadas:
#    - Authorized JavaScript origins: http://localhost:5000
#    - Authorized redirect URIs: http://localhost:5000/callback/google

GOOGLE_CLIENT_ID=seu_google_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui
